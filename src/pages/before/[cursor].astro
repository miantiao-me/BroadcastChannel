---
import List from '../../components/list.astro'
import { getTimelinePage } from '../../lib/telegram'

let channel

try {
  ;({ channel } = await getTimelinePage(Astro, Astro.params.cursor))
} catch {
  return Astro.redirect('/')
}

channel.seo = {
  noindex: true,
}
---

<List channel={channel} pageHeading={channel.title} />
