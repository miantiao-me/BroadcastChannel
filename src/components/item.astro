---
import dayjs from '../lib/dayjs'
import { getEnv } from '../lib/env'

const locale = getEnv(import.meta.env, Astro, 'LOCALE')
const timezone = getEnv(import.meta.env, Astro, 'TIMEZONE')

locale && dayjs.locale(locale)

const { SITE_URL } = Astro.locals
const { post, isItem } = Astro.props

const channel = getEnv(import.meta.env, Astro, 'CHANNEL')
const COMMENTS = getEnv(import.meta.env, Astro, 'COMMENTS')
const REACTIONS = getEnv(import.meta.env, Astro, 'REACTIONS')

const datetime = dayjs(post.datetime).tz(timezone)
const timeago = datetime.isBefore(dayjs().subtract(1, 'w')) ? datetime.format('HH:mm · ll · ddd') : datetime.fromNow()
const hasContent = post.content.length > 0
const hasReactions = Boolean(REACTIONS && post.reactions?.length > 0)
const hasTags = post.tags.length > 0
const articleClass =
  'group overflow-hidden rounded-[28px] border border-line bg-surface/95 p-5 shadow-soft transition duration-200 hover:-translate-y-[0.5px] hover:shadow-[0_16px_40px_-24px_rgba(0,0,0,0.16)]'
const timeBoxClass = 'flex items-center gap-3 leading-none'
const timeDotClass = 'h-[8px] w-[8px] rounded-full bg-accent'
const timeTextClass = 'm-0 flex-1 pl-[10px] text-[14px] font-semibold text-accent'
const itemLinkClass = 'text-accent no-underline hover:underline'
const contentClass =
  'content rounded-[20px] border border-line bg-paper/90 p-5 leading-[1.75] text-[16px] sm:text-[15px]'
const reactionBoxClass = 'mt-5'
const reactionListClass = 'm-0 flex flex-wrap gap-3'
const reactionPillClass =
  'inline-flex items-center gap-1 rounded-full border border-line bg-code px-3 py-2 text-[13px] text-muted'
const reactionPaidClass = 'border-[rgba(255,196,0,0.35)] bg-[rgba(255,196,0,0.12)] text-[#9a6a00]'
const reactionEmojiClass = 'inline-flex items-center text-[14px] leading-none'
const reactionCountClass = 'font-medium opacity-90 [font-variant-numeric:tabular-nums]'
const tagBoxClass =
  'ml-[3px] flex flex-wrap items-center gap-2 border-l-2 border-line pl-[15px] text-[14px] leading-[1.6] sm:pl-[30px]'
const tagPaddingClass = COMMENTS && isItem ? 'pb-[30px]' : 'pb-5'
const tagStandaloneClass = 'pt-[30px]'
const tagLinkClass =
  'inline-block rounded-full border border-line px-[12px] py-[6px] text-[13px] text-muted no-underline transition hover:border-accent hover:text-accent hover:no-underline'
const commentsClass = 'ml-[3px] border-l-2 border-line pb-6 pl-[15px] pt-[6px] sm:pl-[30px]'
const getTagHref = (tag: string) => `/search/result?q=${encodeURIComponent(`#${tag}`)}`
---

<article class={articleClass} style={{ 'view-transition-name': `post-${post.id}` }}>
  <header class={timeBoxClass}>
    <span class={timeDotClass} aria-hidden="true"></span>
    <p class={timeTextClass}>
      <a href={`${SITE_URL}posts/${post.id}`} title={post.datetime} class={itemLinkClass}>
        <time datetime={post.datetime} title={timeago}>{timeago}</time>
      </a>
    </p>
  </header>
  {hasContent && <div class:list={[contentClass, 'content']} set:html={post.content} />}
  {
    hasReactions && (
      <div class:list={[reactionBoxClass, hasContent && '-mt-3 pt-0']}>
        <div class={reactionListClass}>
          {post.reactions.map((reaction) => (
            <span class:list={[reactionPillClass, reaction.isPaid && reactionPaidClass]}>
              <span class={reactionEmojiClass}>
                {reaction.isPaid ? (
                  '\u2B50'
                ) : reaction.emojiImage ? (
                  <img
                    src={reaction.emojiImage}
                    alt={reaction.emoji || 'emoji'}
                    loading="lazy"
                    width="20"
                    height="20"
                    class="block h-[1em] w-[1em]"
                  />
                ) : (
                  reaction.emoji
                )}
              </span>
              <span class={reactionCountClass}>{reaction.count}</span>
            </span>
          ))}
        </div>
      </div>
    )
  }
  {
    hasTags && (
      <footer class:list={[tagBoxClass, tagPaddingClass, !hasContent && tagStandaloneClass]}>
        <span class="tag-icon" aria-hidden="true" />
        {post.tags.map((tag: string) => (
          <a href={getTagHref(tag)} title={tag} class={tagLinkClass}>
            {tag}
          </a>
        ))}
      </footer>
    )
  }

  {
    COMMENTS && isItem && (
      <section class={commentsClass} aria-label="Discussion">
        <details
          class="comment-panel rounded-[20px] border border-line bg-paper px-4 py-4 shadow-soft"
          data-telegram-comments
        >
          <summary class="flex cursor-pointer items-center justify-between gap-3 text-[15px] font-semibold text-heading">
            <span>Discussion</span>
            <span class="rounded-full bg-line px-3 py-1 text-[12px] text-muted">Open to load</span>
          </summary>
          <div class="mt-4">
            <div
              class="rounded-[18px] border border-line bg-surface p-4"
              data-telegram-container
              data-telegram-discussion={`${channel}/${post.id}`}
              data-comments-limit="5"
            />
          </div>
        </details>
      </section>
    )
  }
</article>
